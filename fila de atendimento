#include <stdio.h>

#define MAX 20

int main() {
    int fila[MAX];
    int inicio = 0;
    int fim = 0;
    int quantidade = 0;
    int opcao;
    int numero;

    do {
        printf("\n===== FILA DE ATENDIMENTO =====");
        printf("\n1 - Adicionar cliente");
        printf("\n2 - Atender cliente");
        printf("\n3 - Mostrar proximo cliente");
        printf("\n0 - Sair");
        printf("\nEscolha uma opcao: ");
        scanf("%d", &opcao);

        switch (opcao) {

            case 1: // Adicionar cliente
                if (quantidade == MAX) {
                    printf("Fila cheia! Nao e possivel adicionar mais clientes.\n");
                } else {
                    printf("Digite o numero do cliente: ");
                    scanf("%d", &numero);
                    fila[fim] = numero;
                    fim++;
                    quantidade++;
                    printf("Cliente adicionado a fila.\n");
                }
                break;

            case 2: // Atender cliente
                if (quantidade == 0) {
                    printf("Fila vazia! Nenhum cliente para atender.\n");
                } else {
                    printf("Cliente atendido: %d\n", fila[inicio]);
                    inicio++;
                    quantidade--;
                }
                break;

            case 3: // Mostrar proximo
                if (quantidade == 0) {
                    printf("Fila vazia! Nenhum cliente aguardando.\n");
                } else {
                    printf("Proximo cliente a ser atendido: %d\n", fila[inicio]);
                }
                break;

            case 0:
                printf("Encerrando o programa...\n");
                break;

            default:
                printf("Opcao invalida!\n");
        }

    } while (opcao != 0);

    return 0;
}
