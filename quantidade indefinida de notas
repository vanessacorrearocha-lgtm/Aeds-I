#include <stdio.h>
#define MAX 100

int main()
{
    int notas [MAX];
    int i=0;
    int nota;
    int quantidade=0;
    int soma=0;
    float media;
    int acimaMedia=0;
    int abaixoSete=0;
   
    printf("Digite o valor das notas ou -1 para encerrar: \n");
   
    while(1)
    {
        scanf("%d",&nota);
       
        if(nota==-1)
        {break;}
       
        notas[i]=nota;
        soma=soma+nota;
        quantidade++;
        i++;
    }
   
    printf("A quantidade de notas lidas sao: %d\n", quantidade);
   
    printf("\nA ordem digitada foi: \n");
   
    for(i=0;i<quantidade;i++)
    {
        printf("%d ", notas[i]);
    }
   
    printf("\nOs valores na ordem inversa sao: \n");
   
    for(i=quantidade -1;i>=0;i--)
    {
        printf("%d\n", notas[i]);
    }
   
    printf("\nA soma dos valores e: %d\n", soma);
   
    if(quantidade>0)
    {
        media=(float)soma/quantidade;
        printf("\nA media de valores e: %.2f\n",media);
    }
   
    for(i=0;i<quantidade;i++)
    {
        if(notas[i]>media)
        {
            acimaMedia++;
        }
    }
    printf("Os valores acima da media sao: %d",acimaMedia);
   
    for(i=0;i<quantidade;i++)
    {
        if(notas[i]<7)
        {
            abaixoSete++;
        }
    }
   
    printf("\nA quantidade de notas abaixo de 7 e: %d\n",abaixoSete);
   
    printf("\nPrograma encerrado!!\n");
   
    return(0);
}
