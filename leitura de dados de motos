#include<stdio.h>
#define MAX 3

typedef struct
{
    int modelo;
    float consumo;
}Motos;

int main()
{
    Motos moto[MAX];
    int i;
    int posMotoEconomica=0;
    float litros;
   
    for(i=0;i<MAX;i++)
    {
        printf("\nDigite o modelo da %dª moto: ",i+1);
        scanf("%d",&moto[i].modelo);
        printf("\nDigite o consumo de km/L da %dª moto: ",i+1);
        scanf("%f",&moto[i].consumo);
    }
   
    for(i=1;i<MAX;i++)
    {
        if(moto[i].consumo>moto[posMotoEconomica].consumo)
        {
            posMotoEconomica=i;
        }
    }
   
    printf("\nA moto mais economica e: %d\n",moto[posMotoEconomica].modelo);
    printf("\nO consumo em litros para percorrer 100 km e: \n");
   
    for(i=0;i<MAX;i++)
    {
        litros=100/moto[i].consumo;
        printf("A moto %d consome %.2f litros\n", moto[i].modelo,litros);
       
    }
    return 0;
}
