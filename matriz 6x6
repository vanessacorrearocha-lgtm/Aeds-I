#include<stdio.h>
#include<stdlib.h>
#include<math.h>

int main()

{
    int m[6][6],s1=0,s2=0,i,j,st=0;
   
    for(i=0;i<6;i++)
    {
        for(j=0;j<6;j++)
        {
            printf("Digite o valor da linha %d e coluna %d\n",i,j);
            scanf("%d",&m[i][j]);
        }
    }printf("A matriz digitada foi: \n");
   
    for(i=0;i<6;i++)
    {
        for(j=0;j<6;j++)
        {
            printf("%d ",m[i][j]);
            if(i==j)
            {
                s1=s1+m[i][j];
            }
            else if(i>j)
            {
                s2=s2+m[i][j];
            }
        }
    }
    printf("\nA soma dos elementos abaixo da diagonal principal e: %d\n",st=s1+s2);
   
}
