#include <stdio.h>

int main()
{
    int m[8][8], i, j;
    int soma = 0;

    for(i=0;i<8;i++)
    {
        for(j=0;j<8;j++)
        {
            printf("Digite o valor da linha %d e coluna %d: ", i, j);
            scanf("%d",&m[i][j]);
        }
    }

    for(i=0;i<8;i++)
    {
        for(j=0;j<8;j++)
        {
            if(i < j)
            {
                soma += m[i][j];
            }
        }
    }

    printf("A soma dos elementos acima da diagonal principal e: %d\n", soma);

    return 0;
}
