#include<stdio.h>
#include<stdlib.h>
#include<math.h>
float A[4];
void metade(float A[])
{
printf("A metade do vetor A e: ");
for(int i=0;i<4;i++)
{
A[i]=A[i]/2;
printf("\n%f",A[i]);
}
}
int main()
{

printf("Insira os 4 elementos do vetor A: \n");
for(int i=0;i<4;i++)
{
scanf("%f",&A[i]);
}
metade(A);
}
