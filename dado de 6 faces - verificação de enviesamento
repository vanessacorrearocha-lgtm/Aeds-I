#include<stdio.h>
#include<stdlib.h>
#include<math.h>

int main()

{  
    int jogadas,num;
    int contagem[6]={0};
    int max,min;
   
    printf("Quantas jogadas deseja fazer?\n");
    scanf("%d",&jogadas);
   
    for(int i=0;i<jogadas;i++)
    {
        printf("Digite o resultado da jogada %d (1 a 6): ",i+1);
        scanf("%d",&num);
       
        if(num>=1 && num<=6)
        {
            contagem[num-1]++;
        } else {printf("Numero Invalido. Digite um valor de 1 a 6!\n");
        i--;
        }
    }
   
    printf("A frequencia dos numeros:\n");
   
    for(int i=0;i<6;i++)
    {
        printf("O numero %d saiu %d vezes\n",i+1,contagem[i]);
    }

    max=min=contagem[0];
   
    for(int i=1;i<6;i++)
    {
        if(contagem[i]>max) max=contagem[i];
        if(contagem[i]<min) min=contagem[i];
    }
   
    if ((max-min)>0.2*jogadas)
    {
        printf("O dado pode estar enviesado\n");
    } else{printf("O dado parece nao estar enviesado\n");}
   
    return(0);
}
