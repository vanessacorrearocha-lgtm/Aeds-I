#include<stdio.h>
#define MAX 100

int main()

{
    int num[MAX];
    int valor;
    int i,j;
    int quant=0;
   
    printf("Digite os numeros desejados ou -1 para sair: \n");
   
    while(1)
    {
       scanf("%d",&valor);
       if(valor==-1)
    {
        break;
    }
    if(quant==MAX)
    {
        printf("\nLista Cheia!\n");
        break;
    }
   
    i=0;
   
    while(i<quant && num[i]<valor)
    {
        i++;
    }
    for(j=quant; j>i;j--)
    {
        num[j]=num[j-1];
    }
   
    num[i]=valor;
   
    quant++;
}

printf("\nLista ordenada!\n");

for(i=0;i<quant;i++)
{
    printf ("%d ",num[i]);
}
return 0;
}
